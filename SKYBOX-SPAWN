--[[ 
    CUBNIT SKYBOX - MODO MINIMALISTA V13
    INTERFACE: Apenas ícone (ID: 85260943538226)
    LÓGICA: Sem aplicação de camisa, apenas deformação de malha.
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer

-- --- CONFIGURAÇÕES DE ASSETS ---
local ASSETS = {
    TORSO = 100839513065432,
    ANIM_ID = "rbxassetid://70883871260184",
    ICON_ID = "rbxassetid://85260943538226"
}

-- --- VARIÁVEIS DE ESTADO ---
local skyActive = false
local currentTrack = nil
local lastClick = 0
local doubleClickTime = 0.4 

-- --- CRIAÇÃO DA UI INVISÍVEL ---
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CubnitMinimalSky"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = game:GetService("CoreGui")

local FloatingButton = Instance.new("ImageButton")
FloatingButton.Name = "SkyToggleButton"
FloatingButton.Size = UDim2.new(0, 65, 0, 65) 
FloatingButton.Position = UDim2.new(0.5, -32, 0.1, 0)
FloatingButton.BackgroundTransparency = 1 -- Fundo 100% transparente
FloatingButton.BorderSizePixel = 0
FloatingButton.Image = ASSETS.ICON_ID
FloatingButton.Active = true
FloatingButton.Draggable = true 
FloatingButton.Parent = ScreenGui

-- --- FUNÇÕES CORE ---

local function ToggleSkybox()
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local animator = hum and hum:FindFirstChildOfClass("Animator")
    local RS = game:GetService("ReplicatedStorage")
    
    if not skyActive then
        -- ATIVAR
        skyActive = true
        
        pcall(function()
            -- Removido WearShirt conforme solicitado
            RS.Remotes.ChangeCharacterBody:InvokeServer(unpack({{ASSETS.TORSO}}))
            
            local anim = Instance.new("Animation")
            anim.AnimationId = ASSETS.ANIM_ID
            currentTrack = animator:LoadAnimation(anim)
            currentTrack.Priority = Enum.AnimationPriority.Action4
            currentTrack.Looped = true
            currentTrack:Play()
        end)
    else
        -- DESATIVAR
        skyActive = false
        if currentTrack then currentTrack:Stop() end
        RS.Remotes.ResetCharacterAppearance:FireServer()
    end
end

local function ShutdownScript()
    skyActive = false
    if currentTrack then currentTrack:Stop() end
    game:GetService("ReplicatedStorage").Remotes.ResetCharacterAppearance:FireServer()
    ScreenGui:Destroy()
end

-- --- LÓGICA DE CLIQUE (TOGGLE / SHUTDOWN) ---

FloatingButton.MouseButton1Click:Connect(function()
    local currentTime = tick()
    
    -- Clique Duplo para fechar
    if (currentTime - lastClick) < doubleClickTime then
        ShutdownScript()
        return
    end
    
    lastClick = currentTime
    
    -- Delay para validar clique único
    task.wait(doubleClickTime)
    if (tick() - lastClick) >= doubleClickTime then
        if ScreenGui.Parent then 
            ToggleSkybox()
        end
    end
end)

-- Loop de manutenção visual (Foco no Torso)
RunService.RenderStepped:Connect(function()
    if skyActive and lp.Character then
        pcall(function()
            for _, part in pairs(lp.Character:GetChildren()) do
                -- Esconde membros para a malha do torso ser a única visível no céu
                if part:IsA("BasePart") and (part.Name:find("Arm") or part.Name:find("Leg")) then
                    part.Transparency = 1
                end
            end
        end)
    end
end)
